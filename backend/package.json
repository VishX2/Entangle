{
  "name": "entangle-backend",
  "version": "1.0.0",
  "description": "Entangle API - Express.js + PostgreSQL",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "postinstall": "prisma generate",
    "seed": "prisma db push && node seeds/seed.js",
    "reset": "prisma db push --force-reset && node seeds/seed.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "openai": "^6.26.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "prisma": "^6.9.0"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "prisma db push && node seeds/seed.js"
  }
}
